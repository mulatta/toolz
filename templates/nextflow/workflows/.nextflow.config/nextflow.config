def rootDir = System.getenv('ROOT')

params {
    data_dir    = "${rootDir}/data"
    sample_dir = "${rootDir}/data/samples"
    samplesheet = "${rootDir}/data/samplesheet.csv"
    
    // Direct FASTQ mode (deprecated - use samplesheet instead)
    fastq_pattern   = "${rootDir}/data/fastq/*_R{1,2}.fq.gz"
    fastq_csv       = "${rootDir}/data/fastq_samples.csv"
    
    // Common parameters
    primers         = "${rootDir}/data/primers.csv"
    outdir          = System.getenv('NXF_RESULT_DIR') ?: "${rootDir}/results"
    
    archive_dir     = "${rootDir}/data/archived"
    
    skip_fetch      = false
    skip_prepare    = false
    skip_multiqc    = false
    
    
    library {
        fwd_primer      = "GGGCATACAGACTCCAGATG"
        rev_primer      = "TAGCTCGATCACATGACCA"
        rev_primer_rc   = "TGGTCATGTGATCGAGCTA"
        docking_sequence = "TGGCCACCAT"

        variants = [
            'N40_N10': [random1: 40, random2: 10],
            'N25_N25': [random1: 25, random2: 25],
            'N10_N40': [random1: 10, random2: 40]
        ]
        expected_lengths = [
            'N40_N10': 40 + 10 + 10,
            'N25_N25': 25 + 10 + 25,
            'N10_N40': 10 + 10 + 40 
        ]
        validation = [
            length_tolerance: 4,

            use_length_range: true,
            min_length: 58,
            max_length: 62,

            expected_length: 60
        ]
    }

    fastp {
        merge_min_overlap       = 50
        merge_max_diff_percent  = 5
        merge_min_length        = 70
        merge_max_length        = 150
    }

    // Exact Length = 99 = FPBS (20) + Random (50) + DS (10) + RPBS (19)
    selexqc {
        min_length    = 97
        max_length   = 101
    }
    
    seqtable {
        calculate_rpm = true
        compression = 'snappy'
        export_csv = false
    }

    structure {
        temperature = 37
        no_lonely_pairs = false
    }

    kmers {
        k = 8
        min_count = 2
        max_count = 1000000000
    }

    debug           = System.getenv('PROC_DEBUG')?.toBoolean() ?: false
}

workDir = "${rootDir}/outputs/work"
resume = true
cleanup = false

includeConfig 'base.config'
includeConfig 'modules.config'

manifest {
    name            = 'rna-capture-selex'
    description     = 'RNA Capture-SELEX NGS data processing pipeline'
    version         = '0.1.0'
    defaultBranch   = 'main'
}

profiles {
    nix {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        docker.fixOwnership = true
        process.executor = 'local'
        process.container = 'biotools:latest'
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.executor = 'slurm'
        process.container = 'docker://biotools:latest'
    }
}
